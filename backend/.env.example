# ---------- Server ----------
PORT=5000

# ---------- Database ----------
# Local MongoDB (if installed in WSL):
MONGO_URI=mongodb://127.0.0.1:27017/jarviSeeds
# OR use a free MongoDB Atlas cluster instead (recommended, no install needed):
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster-url>/jarviSeeds?retryWrites=true&w=majority

# ---------- Owner WhatsApp notification (CallMeBot - free) ----------
# 1. Save +34 644 51 71 42 as a contact on the OWNER's phone.
# 2. From the owner's phone, send this exact WhatsApp message to that number:
#    "I allow callmebot to send me messages"
# 3. CallMeBot will reply with your personal apikey. Put it below.
OWNER_WHATSAPP_NUMBER=91XXXXXXXXXX
OWNER_CALLMEBOT_APIKEY=123456

# ---------- Customer SMS notification (Textbelt - free tier) ----------
# The default key "textbelt" gives 1 FREE SMS per day worldwide (good for testing/low volume).
# For real volume, buy a cheap Textbelt key at https://textbelt.com
# or swap the code in utils/notify.js for Fast2SMS / Twilio (see README).
TEXTBELT_KEY=textbelt

# ---------- Simple admin protection for the export/list endpoints ----------
ADMIN_KEY=change-this-secret
